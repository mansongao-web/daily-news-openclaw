# OpenRouter / 直连 Anthropic 的 API Key
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx

# 飞书自定义机器人 Webhook（群设置 → 群机器人 → 添加自定义机器人）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 飞书签名校验 secret（机器人勾选了"签名校验"才填，否则留空）
FEISHU_SECRET=

# 可选：外部触发 hook 的共享密钥
OPENCLAW_HOOK_TOKEN=please-change-me
